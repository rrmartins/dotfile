// ------------------------------------------------------------
// ZELLIJ 0.44+ CLEAN CONFIG
// Minimal, moderna e estável para LazyVim / Neovim workflow
// ------------------------------------------------------------

keybinds clear-defaults=true {
    locked {
        bind "Ctrl m" { SwitchToMode "Normal"; }
        bind "Ctrl Left" { MoveFocusOrTab "Left"; }
        bind "Ctrl Down" { MoveFocus "Down"; }
        bind "Ctrl Up" { MoveFocus "Up"; }
        bind "Ctrl Right" { MoveFocusOrTab "Right"; }
    }

    normal {
        bind "Ctrl m" { SwitchToMode "Locked"; }

//      bind "h" { MoveFocusOrTab "Left"; }
//      bind "j" { MoveFocus "Down"; }
//      bind "k" { MoveFocus "Up"; }
//      bind "l" { MoveFocusOrTab "Right"; }

        // panes
        bind "n" { NewPane; SwitchToMode "Locked"; }
        bind "v" { NewPane "right"; SwitchToMode "Locked"; }
        bind "h" { NewPane "down"; SwitchToMode "Locked"; }
        bind "x" { CloseFocus; SwitchToMode "Locked"; }

        bind "f" { 
          ToggleFocusFullscreen;
          SwitchToMode "Locked";
        }

        bind "1" { GoToTab 1; SwitchToMode "Locked"; }
        bind "2" { GoToTab 2; SwitchToMode "Locked"; }
        bind "3" { GoToTab 3; SwitchToMode "Locked"; }
        bind "4" { GoToTab 4; SwitchToMode "Locked"; }
        bind "5" { GoToTab 5; SwitchToMode "Locked"; }
        bind "6" { GoToTab 6; SwitchToMode "Locked"; }
        bind "7" { GoToTab 7; SwitchToMode "Locked"; }
        bind "8" { GoToTab 8; SwitchToMode "Locked"; }

        bind "t" { NewTab; SwitchToMode "Locked"; }
        bind "q" { CloseTab; SwitchToMode "Locked"; }

        bind "s" {
            LaunchOrFocusPlugin "zellij:session-manager" {
                floating true
            };
        }

        bind "r" { SwitchToMode "RenameTab"; TabNameInput 0; }
        bind "H" { MoveTab "Left"; }
        bind "L" { MoveTab "Right"; }
        bind "Tab" { GoToNextTab; }
        bind "Shift Tab" { GoToPreviousTab; }
    }

    resize {
        bind "Esc" { SwitchToMode "Locked"; }
        bind "h" { Resize "Increase Left"; }
        bind "j" { Resize "Increase Down"; }
        bind "k" { Resize "Increase Up"; }
        bind "l" { Resize "Increase Right"; }
    }

    pane {
        bind "Esc" { SwitchToMode "Locked"; }
    }

    tab {
        bind "Esc" { SwitchToMode "Locked"; }
    }

    scroll {
        bind "Esc" { SwitchToMode "Locked"; }
    }

    renametab {
        bind "Enter" { SwitchToMode "Locked"; }
        bind "Esc" { UndoRenameTab; SwitchToMode "Locked"; }
    }

    renamepane {
        bind "Enter" { SwitchToMode "Locked"; }
        bind "Esc" { UndoRenamePane; SwitchToMode "Locked"; }
    }
}


// ESCONDE A TAB BAR DE CIMA
hide_tab_bar true

// ------------------------------------------------------------
// UI
// ------------------------------------------------------------

theme "dracula"

default_mode "Locked"

simplified_ui false

pane_frames false

auto_layout true

mouse_mode true

copy_on_select true

scroll_buffer_size 10000

copy_command "pbcopy"

// ------------------------------------------------------------
// SESSION
// ------------------------------------------------------------

session_serialization false

serialize_pane_viewport false

mirror_session false

on_force_close "quit"

// ------------------------------------------------------------
// LAYOUTS / PLUGINS
// ------------------------------------------------------------

layout_dir "~/.config/zellij/layouts"

plugins {
    tab-bar location="zellij:tab-bar"
    status-bar location="zellij:status-bar"
    strider location="zellij:strider"
    session-manager location="zellij:session-manager"
    configuration location="zellij:configuration"
    plugin-manager location="zellij:plugin-manager"
}

// ------------------------------------------------------------
// THEMES
// ------------------------------------------------------------

themes {
    dracula {
        fg 248 248 242
        bg 40 42 54
        red 255 85 85
        green 80 250 123
        yellow 241 250 140
        blue 98 114 164
        magenta 255 121 198
        orange 255 184 108
        cyan 139 233 253
        black 0 0 0
        white 255 255 255
    }
}
